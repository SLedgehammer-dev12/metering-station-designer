{
  "metadata": {"standard": "ISO 5167-2:2022 + AGA Report No.3", "version": "1.0"},
  "components": {
    "orifice_plate": {
      "name_tr": "Orifis Plakası",
      "name_en": "Orifice Plate",
      "standard": "ISO 5167-2 §5",
      "parameters": {
        "d_diameter": {
          "label_tr": "Delik Çapı (d)",
          "label_en": "Bore Diameter (d)",
          "unit": "mm",
          "points": {"count": 4, "angular": true, "spacing": 45},
          "tolerance": {"type": "percentage_or_absolute", "percentage": 0.05, "absolute_mm": 0.01, "base_param": "d", "use": "larger"},
          "clause": "ISO 5167-2 §5.1.3",
          "criticality": "CRITICAL",
          "uncertainty_factor": 0.5
        },
        "E_thickness": {
          "label_tr": "Plaka Kalınlığı (E)",
          "label_en": "Plate Thickness (E)",
          "unit": "mm",
          "points": {"count": 1},
          "tolerance": {"type": "range_from_D", "min_factor": 0.005, "max_factor": 0.02},
          "clause": "ISO 5167-2 §5.1.4",
          "criticality": "MAJOR"
        },
        "e_edge_thickness": {
          "label_tr": "Kenar Kalınlığı (e)",
          "label_en": "Edge Thickness (e)",
          "unit": "mm",
          "points": {"count": 1},
          "tolerance": {"type": "range_from_D", "min_factor": 0.005, "max_factor": 0.02},
          "clause": "ISO 5167-2 §5.1.5",
          "criticality": "CRITICAL"
        },
        "edge_sharpness": {
          "label_tr": "Kenar Keskinliği",
          "label_en": "Edge Sharpness",
          "unit": "qualitative",
          "points": {"count": 1},
          "tolerance": {"type": "enum", "accept": ["sharp", "faint_light"], "reject": ["visible_light", "rounded"]},
          "options": [
            {"value": "sharp", "label_tr": "Işık yansıması YOK (Keskin)", "label_en": "No light reflection (Sharp)", "status": "PASS"},
            {"value": "faint_light", "label_tr": "Kılcal ışık (Kabul edilebilir)", "label_en": "Faint light (Acceptable)", "status": "CONDITIONAL"},
            {"value": "visible_light", "label_tr": "Belirgin yansıma (Red)", "label_en": "Visible reflection (Reject)", "status": "FAIL"},
            {"value": "rounded", "label_tr": "Yuvarlak kenar (Red)", "label_en": "Rounded edge (Reject)", "status": "FAIL"}
          ],
          "clause": "ISO 5167-2 §5.1.6",
          "criticality": "CRITICAL"
        },
        "Ra_upstream": {
          "label_tr": "Yüzey Pürüzlülüğü Ra (upstream)",
          "label_en": "Surface Roughness Ra (upstream)",
          "unit": "μm",
          "points": {"count": 1},
          "tolerance": {"type": "conditional_max", "conditions": [
            {"if": {"param": "beta", "op": ">", "value": 0.6}, "max": 0.4},
            {"if": {"param": "beta", "op": "<=", "value": 0.6}, "max": 0.8}
          ]},
          "clause": "ISO 5167-2 §5.1.2",
          "criticality": "MAJOR"
        },
        "flatness": {
          "label_tr": "Düzlemsellik (upstream yüz)",
          "label_en": "Flatness (upstream face)",
          "unit": "mm/100mm",
          "points": {"count": 1},
          "tolerance": {"type": "max_value", "value": 0.01},
          "clause": "ISO 5167-2 §5.1.1",
          "criticality": "MAJOR"
        },
        "chamfer_angle": {
          "label_tr": "Giriş Pah Açısı",
          "label_en": "Inlet Chamfer Angle",
          "unit": "°",
          "points": {"count": 1},
          "tolerance": {"type": "range", "min": 30.0, "max": 60.0},
          "clause": "ISO 5167-2 §5.1.5",
          "criticality": "MINOR"
        }
      }
    },
    "meter_tube": {
      "name_tr": "Metre Tüpü",
      "name_en": "Meter Tube",
      "standard": "ISO 5167-2 §6 + AGA 3 Part 2",
      "parameters": {
        "D_diameter": {
          "label_tr": "İç Çap (D)",
          "label_en": "Internal Diameter (D)",
          "unit": "mm",
          "points": {"count": 12, "angular": true, "positions": 3, "angular_count": 4, "labels": ["0°@1D","90°@1D","45°@1D","135°@1D","0°@3D","90°@3D","45°@3D","135°@3D","0°@5D","90°@5D","45°@5D","135°@5D"]},
          "tolerance": {"type": "percentage", "value": 0.3, "base_param": "D"},
          "clause": "ISO 5167-2 §6.2",
          "criticality": "CRITICAL",
          "uncertainty_factor": 0.3
        },
        "ovality": {
          "label_tr": "Ovallik (Max(D) - Min(D))",
          "label_en": "Ovality (Max(D) - Min(D))",
          "unit": "mm",
          "points": {"count": 1, "computed": true},
          "tolerance": {"type": "percentage", "value": 0.3, "base_param": "D"},
          "clause": "ISO 5167-2 §6.2",
          "criticality": "MAJOR"
        },
        "upstream_length": {
          "label_tr": "Upstream Düz Boru Boyu",
          "label_en": "Upstream Straight Length",
          "unit": "mm",
          "points": {"count": 1},
          "tolerance": {"type": "min_length_D", "min_factor": 15, "beta_dependent": true, "default_min_D": 15},
          "clause": "ISO 5167-2 §6.3 Tablo 3",
          "criticality": "MAJOR"
        },
        "downstream_length": {
          "label_tr": "Downstream Düz Boru Boyu",
          "label_en": "Downstream Straight Length",
          "unit": "mm",
          "points": {"count": 1},
          "tolerance": {"type": "min_length_D", "min_factor": 5, "default_min_D": 5},
          "clause": "ISO 5167-2 §6.3",
          "criticality": "MINOR"
        },
        "internal_roughness": {
          "label_tr": "İç Yüzey Pürüzlülüğü",
          "label_en": "Internal Surface Roughness",
          "unit": "μm",
          "points": {"count": 1},
          "tolerance": {"type": "max_value", "value": 30},
          "clause": "ISO 5167-2 §6.1",
          "criticality": "MINOR"
        },
        "weld_protrusion": {
          "label_tr": "Kaynak Çıkıntısı (iç)",
          "label_en": "Weld Protrusion (internal)",
          "unit": "mm",
          "points": {"count": 1},
          "tolerance": {"type": "max_value", "value": 2.0},
          "clause": "ISO 5167-2 §6.1",
          "criticality": "MINOR"
        },
        "misalignment": {
          "label_tr": "Eksenel Kaçıklık (misalignment)",
          "label_en": "Axial Misalignment",
          "unit": "°",
          "points": {"count": 1},
          "tolerance": {"type": "max_value", "value": 0.5},
          "clause": "ISO 5167-2 §6.3",
          "criticality": "MAJOR"
        }
      }
    }
  }
}
